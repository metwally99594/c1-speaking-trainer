# Piper TTS backend — copy to .env and adjust paths

# Path to the piper binary
# Linux:   PIPER_PATH=./piper
# Windows: PIPER_PATH=./piper.exe
PIPER_PATH=./piper

# Path to the .onnx voice model (German)
PIPER_MODEL=../models/de_DE-eva_k-medium.onnx

# Default speech speed (0.5 – 2.0; 1.0 = normal)
PIPER_SPEED=1.0

# Port the server listens on
PORT=8000

# CORS: comma-separated origins allowed to call this server
# Must include your Vite dev server and production frontend URL
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
